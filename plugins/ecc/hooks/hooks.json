{
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags.js\" stop:format-typecheck scripts/hooks/stop-format-typecheck.js standard,strict",
            "timeout": 300
          }
        ],
        "description": "在每次响应结束时，批量格式化本轮编辑过的 JS/TS 文件并执行 typecheck，而不是每次 Edit 后都运行",
        "id": "stop:format-typecheck"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/desktop-notify.js\"",
            "timeout": 30,
            "async": true
          }
        ],
        "description": "在每次响应后发送桌面通知",
        "id": "stop:desktop-notify"
      }
    ]
  }
}